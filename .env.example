# Variables d'environnement — copier en .env.local pour le développement
# Toutes les variables préfixées NEXT_PUBLIC_ sont exposées côté client.

# ── Site ────────────────────────────────────────────────────────
# URL du site en production (utilisé pour les canonicals et sitemap)
NEXT_PUBLIC_SITE_URL=https://votre-domaine.fr

# Nom du site affiché dans les metas et l'en-tête
NEXT_PUBLIC_SITE_NOM=MonSiteAvis

# ── Analytics ───────────────────────────────────────────────────
# Google Tag Manager (recommandé — contient GA4 + Clarity + autres tags)
# Obtenir l'ID sur : https://tagmanager.google.com/
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics 4 (utilisé uniquement si GTM n'est pas configuré)
# Obtenir l'ID sur : https://analytics.google.com/
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Microsoft Clarity (heatmaps + session recordings — gratuit)
# Obtenir l'ID sur : https://clarity.microsoft.com/
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# ── Affiliation — Tracking server-side (GA4 Measurement Protocol) ───────────
# Ces variables sont SERVER-SIDE uniquement (pas de préfixe NEXT_PUBLIC_).
# Elles permettent de tracker les clics /go/[slug] même derrière un ad blocker.
#
# GA4_MEASUREMENT_ID : même ID que NEXT_PUBLIC_GA_ID (ex: G-XXXXXXXXXX)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
#
# GA4_MEASUREMENT_API_SECRET : créer dans GA4 Admin > Flux de données > [votre flux]
#   > Secrets d'API Measurement Protocol > Créer
GA4_MEASUREMENT_API_SECRET=votre_secret_api

# ── Notes de déploiement ────────────────────────────────────────
# 1. Remplacer https://votre-domaine.fr par l'URL réelle dès que le domaine est choisi
# 2. Configurer GTM avant la mise en ligne (GA4 + Clarity via GTM)
# 3. Vérifier la propriété dans Google Search Console avec la meta tag
# 4. Soumettre le sitemap (https://votre-domaine.fr/sitemap.xml) dans GSC
# 5. Créer le secret Measurement Protocol dans GA4 Admin et renseigner GA4_MEASUREMENT_API_SECRET
